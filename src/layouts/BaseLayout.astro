---
import '../styles/global.css';

export interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
}

const {
  title,
  description = "Cast Design Fireplaces crafts premium cast stone fireplace mantels, surrounds, and architectural stone products for DFW area homes. Custom designs. Free consultation.",
  canonical,
  ogImage = "/og-image.jpg",
} = Astro.props;

const siteUrl = "https://dallasfireplaces.com";
const fullCanonical = canonical ? `${siteUrl}${canonical}` : siteUrl;
// ogImage may be an absolute CDN URL (e.g. Sanity), a local /path, or null/undefined
const resolvedOgImage = ogImage ?? "/og-image.jpg";
const fullOgImage = resolvedOgImage.startsWith('http') ? resolvedOgImage : `${siteUrl}${resolvedOgImage}`;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <!-- Primary Meta -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={fullCanonical} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={fullCanonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={fullOgImage} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={fullOgImage} />

    <!-- LocalBusiness Schema — enables star ratings in Google search results -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "@id": `${siteUrl}/#business`,
      "name": "Cast Design Fireplaces",
      "description": description,
      "url": siteUrl,
      "telephone": "+1-214-621-4820",
      "email": "hello@dallasfireplaces.com",
      "image": `${siteUrl}/og-image.jpg`,
      "logo": `${siteUrl}/favicon-32x32.png`,
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "309 N Belt Line Rd #117",
        "addressLocality": "Irving",
        "addressRegion": "TX",
        "postalCode": "75061",
        "addressCountry": "US"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 32.8140,
        "longitude": -97.0641
      },
      "hasMap": "https://maps.google.com/?q=309+N+Belt+Line+Rd+%23117+Irving+TX+75061",
      "openingHoursSpecification": [
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"],
          "opens": "08:00",
          "closes": "17:00"
        }
      ],
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "4.9",
        "reviewCount": "200",
        "bestRating": "5",
        "worstRating": "1"
      },
      "priceRange": "$$$$",
      "areaServed": [
        { "@type": "City", "name": "Dallas" },
        { "@type": "City", "name": "Fort Worth" },
        { "@type": "City", "name": "Irving" },
        { "@type": "City", "name": "Plano" },
        { "@type": "City", "name": "McKinney" },
        { "@type": "City", "name": "Frisco" },
        { "@type": "City", "name": "Southlake" },
        { "@type": "City", "name": "Arlington" },
        { "@type": "City", "name": "Grapevine" },
        { "@type": "City", "name": "Colleyville" }
      ]
    })} />

    <!-- Preload Zodiak (critical heading font) -->
    <link rel="preload" href="/fonts/Zodiak-Regular.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/Zodiak-Bold.woff2" as="font" type="font/woff2" crossorigin />

    <!-- Inter (UI sans-serif) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />

    <!-- Page-specific head content (extra schema, meta, etc.) -->
    <slot name="head" />

    <!-- Fathom - beautiful, simple website analytics -->
    <script src="https://cdn.usefathom.com/script.js" data-site="EJRNZZQO" defer></script>
    <!-- / Fathom -->
  </head>
  <body>
    <slot />
  </body>
</html>
