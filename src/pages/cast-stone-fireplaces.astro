---
import BaseLayout from '../layouts/BaseLayout.astro';

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "Cast Design Fireplaces",
  "description": "Custom cast stone fireplace mantels, surrounds, and outdoor fireplaces handcrafted for Dallas–Fort Worth homes.",
  "url": "https://dallasfireplaces.com",
  "telephone": "+1-214-621-4820",
  "email": "hello@dallasfireplaces.com",
  "image": "https://dallasfireplaces.com/images/gallery/Ashton/CAST Design Fireplaces - Ashton.jpeg",
  "priceRange": "$$$",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "309 N Belt Line Rd #117",
    "addressLocality": "Irving",
    "addressRegion": "TX",
    "postalCode": "75061",
    "addressCountry": "US"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 32.8141,
    "longitude": -96.9488
  },
  "openingHoursSpecification": [
    { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"], "opens": "08:00", "closes": "17:00" },
    { "@type": "OpeningHoursSpecification", "dayOfWeek": "Saturday", "opens": "09:00", "closes": "14:00" }
  ],
  "areaServed": ["Dallas","Fort Worth","Plano","Southlake","McKinney","Frisco","Colleyville","Flower Mound","Keller","Irving","Westlake"]
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How much does a cast stone fireplace cost?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Cast stone fireplaces from CAST Design range from approximately $3,500 for a simpler mantel-only installation to $15,000 or more for a full custom surround with hearth and complex carving detail. The cost depends on the size, the complexity of the design, and whether you're doing a new installation or a firebox replacement. We provide a fixed-price quote after the free in-home consultation — no hidden fees, no surprises."
      }
    },
    {
      "@type": "Question",
      "name": "Is cast stone fireplace heat-resistant?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. Cast stone is a cement-based material and is naturally heat-tolerant. It will not warp, melt, or degrade with normal fireplace use. Our cast stone mix is specifically engineered to handle the thermal cycling of regular fireplace operation across decades."
      }
    },
    {
      "@type": "Question",
      "name": "How does cast stone compare to natural stone for a fireplace?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Natural stone fireplaces are beautiful but come with trade-offs: high cost, limited design control, and the inconsistency inherent to quarried material. Cast stone delivers the same visual warmth and physical weight at a lower cost, with precise design control and consistent quality. For custom fireplace design, cast stone is actually the superior material for most applications."
      }
    },
    {
      "@type": "Question",
      "name": "Can a cast stone fireplace be installed on an existing firebox?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Absolutely. This is the most common scenario — a homeowner has an existing gas or wood-burning firebox and wants to upgrade from a dated or builder-grade surround to a proper cast stone mantel and surround. We work around your existing firebox dimensions, and our team handles all the installation logistics."
      }
    },
    {
      "@type": "Question",
      "name": "What fireplace styles are available in cast stone?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Cast stone is one of the most design-flexible fireplace materials available. We produce traditional, transitional, contemporary, modern, rustic, and custom architectural styles. If you can describe it or show us a reference image, we can usually build it."
      }
    },
    {
      "@type": "Question",
      "name": "Do you serve areas outside of Dallas?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. We serve the entire Dallas–Fort Worth metroplex, including Fort Worth, Plano, Southlake, McKinney, Frisco, Colleyville, Westlake, Flower Mound, Keller, and all surrounding communities. Contact us to confirm service in your area."
      }
    }
  ]
};
