</main>

<!-- ── Form logic ───────────────────────────────────────────────────────────── -->
<script>
  const form        = document.getElementById('consultation-form') as HTMLFormElement;
  const submitBtn   = document.getElementById('submit-btn') as HTMLButtonElement;
  const submitLabel = document.getElementById('submit-label') as HTMLElement;
  const submitArrow = document.getElementById('submit-arrow') as HTMLElement;
  const submitSpinner = document.getElementById('submit-spinner') as HTMLElement;
  const errorBanner = document.getElementById('form-error-banner') as HTMLElement;
  const formView    = document.getElementById('form-view') as HTMLElement;
  const successView = document.getElementById('success-view') as HTMLElement;

  const TOTAL_STEPS = 3;
  let currentStep = 1;

  // ── Progress indicator ────────────────────────────────────────────────────
  function updateProgress(step: number) {
    document.getElementById('fp')?.setAttribute('aria-valuenow', String(step));
    for (let i = 1; i <= TOTAL_STEPS; i++) {
      const dot = document.getElementById(`fp-${i}`);
      dot?.classList.remove('is-active', 'is-done');
      if (i < step)  dot?.classList.add('is-done');
      if (i === step) dot?.classList.add('is-active');
    }
    // Lines
    for (let i = 1; i < TOTAL_STEPS; i++) {
      const line = document.getElementById(`fp-line-${i}`);
      line?.classList.toggle('is-done', i < step);
    }
  }

  // ── Show step ─────────────────────────────────────────────────────────────
  function showStep(step: number) {
    for (let i = 1; i <= TOTAL_STEPS; i++) {
      const el = document.getElementById(`step-${i}`) as HTMLElement;
      el.hidden = i !== step;
    }
    currentStep = step;
    updateProgress(step);
    document.getElementById('form-card')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  // ── Tile selection ─────────────────────────────────────────────────────────
  document.querySelectorAll('.ft input[type="radio"]').forEach((radio) => {
    radio.addEventListener('change', () => {
      const name = (radio as HTMLInputElement).name;
      document.querySelectorAll(`.ft input[name="${name}"]`).forEach((r) => {
        (r.closest('.ft') as HTMLElement)?.classList.remove('is-selected');
      });
      (radio.closest('.ft') as HTMLElement)?.classList.add('is-selected');
    });
  });

  // ── Next buttons ───────────────────────────────────────────────────────────
  document.querySelectorAll<HTMLButtonElement>('.form-next').forEach((btn) => {
    btn.addEventListener('click', () => {
      const next = parseInt(btn.dataset.next ?? '2');
      if (currentStep === 1) {
        const projectType = (form.querySelector('input[name="projectType"]:checked') as HTMLInputElement | null)?.value;
        if (!projectType) {
          showError('err-projectType', 'Please select a project type to continue.');
          return;
        }
        showError('err-projectType', '');
      }
      showStep(next);
    });
  });

  // ── Back buttons ───────────────────────────────────────────────────────────
  document.querySelectorAll<HTMLButtonElement>('.form-back').forEach((btn) => {
    btn.addEventListener('click', () => showStep(parseInt(btn.dataset.back ?? '1')));
  });

  // ── Error helper ───────────────────────────────────────────────────────────
  function showError(id: string, msg: string) {
    const el = document.getElementById(id);
    if (el) { el.textContent = msg; el.style.display = msg ? 'block' : 'none'; }
  }

  // ── Validate step 3 ────────────────────────────────────────────────────────
  function validateStep3(): boolean {
    let ok = true;

    const firstName = (form.querySelector('#firstName') as HTMLInputElement).value.trim();
    if (!firstName) { showError('err-firstName', 'First name is required.'); ok = false; }
    else showError('err-firstName', '');

    const lastName = (form.querySelector('#lastName') as HTMLInputElement).value.trim();
    if (!lastName) { showError('err-lastName', 'Last name is required.'); ok = false; }
    else showError('err-lastName', '');

    const email = (form.querySelector('#email') as HTMLInputElement).value.trim();
    if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      showError('err-email', 'A valid email address is required.'); ok = false;
    } else showError('err-email', '');

    const phone = (form.querySelector('#phone') as HTMLInputElement).value.trim();
    if (!phone) { showError('err-phone', 'Phone number is required.'); ok = false; }
    else showError('err-phone', '');

    const smsConsent = (form.querySelector('#smsConsent') as HTMLInputElement).checked;
    if (!smsConsent) { showError('err-smsConsent', 'Please accept the SMS consent to continue.'); ok = false; }
    else showError('err-smsConsent', '');

    return ok;
  }

  // ── Submit ─────────────────────────────────────────────────────────────────
  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorBanner.style.display = 'none';
    if (!validateStep3()) return;

    submitBtn.disabled = true;
    submitLabel.textContent = 'Sending…';
    submitArrow.style.display = 'none';
    submitSpinner.style.display = 'inline';

    const payload = {
      projectType: (form.querySelector('input[name="projectType"]:checked') as HTMLInputElement | null)?.value ?? '',
      style:       (form.querySelector('input[name="style"]:checked') as HTMLInputElement | null)?.value ?? '',
      timeline:    (form.querySelector('#timeline') as HTMLSelectElement).value,
      details: {
        room:          (form.querySelector('#room') as HTMLSelectElement).value,
        fireplaceType: (form.querySelector('#fireplaceType') as HTMLSelectElement).value,
      },
      contact: {
        firstName: (form.querySelector('#firstName') as HTMLInputElement).value.trim(),
        lastName:  (form.querySelector('#lastName') as HTMLInputElement).value.trim(),
        fullName:  `${(form.querySelector('#firstName') as HTMLInputElement).value.trim()} ${(form.querySelector('#lastName') as HTMLInputElement).value.trim()}`,
        phone:     (form.querySelector('#phone') as HTMLInputElement).value.trim(),
        email:     (form.querySelector('#email') as HTMLInputElement).value.trim(),
        city:      (form.querySelector('#city') as HTMLInputElement).value.trim(),
        message:   (form.querySelector('#message') as HTMLTextAreaElement).value.trim(),
        smsConsent: true,
        marketingConsent: (form.querySelector('#marketingConsent') as HTMLInputElement).checked,
      },
    };

    try {
      const res = await fetch('https://castdesign-form.vercel.app/api/quote-request', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
      if (!res.ok) throw new Error('Server error');
      formView.style.display = 'none';
      successView.style.display = 'block';
      successView.scrollIntoView({ behavior: 'smooth', block: 'start' });
    } catch {
      errorBanner.style.display = 'flex';
      submitBtn.disabled = false;
      submitLabel.textContent = 'Send My Request';
      submitArrow.style.display = 'inline';
      submitSpinner.style.display = 'none';
    }
  });

  // Init
  updateProgress(1);
</script>

</BaseLayout>
