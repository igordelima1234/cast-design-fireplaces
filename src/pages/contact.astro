---
import BaseLayout from '../layouts/BaseLayout.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Free Consultation | Cast Design Fireplaces | DFW Cast Stone"
  description="Request a free, no-obligation consultation for your cast stone fireplace mantel, surround, or custom stone project. Serving all Dallas–Fort Worth communities."
  canonical="/contact"
>

<style>
  /* ── Hero CTA ─────────────────────────────────────────────────────────────── */
  .hero-cta-wrap {
    margin-top: 28px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 12px;
  }
  .hero-cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: #F5F0EA;
    color: #2C2A26;
    border: none;
    border-radius: 6px;
    padding: 15px 28px;
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 0.95rem;
    font-weight: 700;
    text-decoration: none;
    letter-spacing: 0.01em;
    transition: background 0.18s, transform 0.18s;
  }
  .hero-cta-btn:hover { background: #fff; transform: translateY(-1px); }
  .hero-cta-note {
    font-size: 0.78rem;
    color: rgba(245,240,234,0.65);
    font-family: 'Inter', system-ui, sans-serif;
  }

  /* ── Contact section — single column ─────────────────────────────────────── */
  .contact-section { padding: 80px 0; }
  .contact-section .container {
    display: block;
    max-width: 860px;
    margin: 0 auto;
  }
  .contact-intro { margin-bottom: 52px; }
  .contact-intro .contact-info__heading { max-width: 560px; }
  .contact-intro .contact-info__body   { max-width: 560px; }

  /* 2-column steps grid */
  .contact-steps-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px 48px;
    margin-bottom: 60px;
  }
  @media (max-width: 640px) {
    .contact-steps-grid { grid-template-columns: 1fr; gap: 24px; }
  }

  /* 4-column contact details */
  .contact-details-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
    border-top: 1px solid var(--color-cream-dark);
    padding-top: 40px;
  }
  @media (max-width: 860px) { .contact-details-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 480px) { .contact-details-grid { grid-template-columns: 1fr; } }

  /* ── CTA section ──────────────────────────────────────────────────────────── */
  .contact-cta-section {
    background: var(--color-stone);
    padding: 80px 0;
    text-align: center;
  }
  .contact-cta-section__label {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-gold);
    font-family: var(--ff-sans);
    margin-bottom: 16px;
  }
  .contact-cta-section__heading {
    font-family: var(--ff-serif);
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    font-weight: 400;
    color: var(--color-cream);
    letter-spacing: var(--heading-tracking);
    margin-bottom: 16px;
    line-height: 1.2;
  }
  .contact-cta-section__sub {
    font-size: 1rem;
    color: rgba(245,240,234,0.65);
    font-family: var(--ff-sans);
    margin-bottom: 36px;
    max-width: 480px;
    margin-left: auto;
    margin-right: auto;
    line-height: 1.6;
  }
  .contact-cta-section__actions {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    flex-wrap: wrap;
  }
  .contact-cta-section__btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--color-cream);
    color: var(--color-stone);
    border: none;
    border-radius: 6px;
    padding: 15px 28px;
    font-family: var(--ff-sans);
    font-size: 0.95rem;
    font-weight: 700;
    text-decoration: none;
    transition: background 0.18s;
  }
  .contact-cta-section__btn:hover { background: #fff; }
  .contact-cta-section__call {
    color: rgba(245,240,234,0.7);
    font-family: var(--ff-sans);
    font-size: 0.88rem;
    text-decoration: none;
    transition: color 0.15s;
  }
  .contact-cta-section__call:hover { color: var(--color-cream); }
</style>

  <!-- ═══ TOP BAR ═══ -->
  <div class="top-bar">
    <div class="container">
      <div class="top-bar__areas">
        <span>Areas We Serve</span>
        <a href="/service-areas/dallas">Dallas</a>
        <span class="sep">·</span>
        <a href="/service-areas/fort-worth">Fort Worth</a>
        <span class="sep">·</span>
        <a href="/service-areas/plano">Plano</a>
        <span class="sep">·</span>
        <a href="/service-areas/southlake">Southlake</a>
        <span class="sep">·</span>
        <a href="/service-areas/mckinney">McKinney</a>
        <span class="sep">·</span>
        <a href="/service-areas">All DFW</a>
      </div>
      <div class="top-bar__phone">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
        </svg>
        Call for a Free Consultation&nbsp;
        <a href="tel:+12146214820">(214) 621-4820</a>
      </div>
    </div>
  </div>

  <!-- ═══ NAVIGATION ═══ -->
  <nav class="nav" aria-label="Main navigation">
    <div class="container">
      <a href="/" class="nav__logo" aria-label="Cast Design Fireplaces – Home">
        <span class="nav__logo-main">Cast Design</span>
        <span class="nav__logo-sub">Fireplaces</span>
      </a>
      <ul class="nav__links" role="list">
        <li><a href="/gallery">Gallery</a></li>
        <li><a href="/about">About</a></li>
        <li><a href="/blog">Blog</a></li>
        <li><a href="/contact" class="nav__cta" aria-current="page">Free Consultation</a></li>
      </ul>
      <button class="nav__hamburger" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-menu">
        <span></span><span></span><span></span>
      </button>
    </div>
  </nav>

  <!-- ═══ MOBILE MENU ═══ -->
  <div class="mobile-menu" id="mobile-menu" aria-hidden="true">
    <div class="mobile-menu__backdrop"></div>
    <div class="mobile-menu__panel">
      <div class="mobile-menu__header">
        <a href="/" class="nav__logo" aria-label="Cast Design Fireplaces – Home">
          <span class="nav__logo-main">Cast Design</span>
          <span class="nav__logo-sub">Fireplaces</span>
        </a>
        <button class="mobile-menu__close" aria-label="Close menu">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
      <nav class="mobile-menu__nav" aria-label="Mobile navigation">
        <ul role="list">
          <li><a href="/gallery">Gallery</a></li>
          <li><a href="/about">About</a></li>
          <li><a href="/blog">Blog</a></li>
        </ul>
      </nav>
      <div class="mobile-menu__footer">
        <a href="/consultation" class="mobile-menu__cta">
          Schedule Free Consultation
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
          </svg>
        </a>
        <a href="tel:+12146214820" class="mobile-menu__call">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
          </svg>
          (214) 621-4820
        </a>
      </div>
    </div>
  </div>

  <script>
    const hamburger = document.querySelector<HTMLButtonElement>('.nav__hamburger');
    const closeBtn  = document.querySelector<HTMLButtonElement>('.mobile-menu__close');
    const backdrop  = document.querySelector<HTMLElement>('.mobile-menu__backdrop');
    const menu      = document.querySelector<HTMLElement>('.mobile-menu');
    function openMenu() {
      menu!.classList.add('is-open');
      menu!.setAttribute('aria-hidden', 'false');
      hamburger!.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
    }
    function closeMenu() {
      menu!.classList.remove('is-open');
      menu!.setAttribute('aria-hidden', 'true');
      hamburger!.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    }
    hamburger?.addEventListener('click', openMenu);
    closeBtn?.addEventListener('click', closeMenu);
    backdrop?.addEventListener('click', closeMenu);
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeMenu(); });
  </script>

  <!-- ═══ PAGE HERO ═══ -->
  <section class="page-hero contact-hero" aria-label="Contact page hero">
    <img
      class="page-hero__bg"
      src="/images/CAST-Design-Company-Modern-Fireplace-Mantel-Modern Living Room.jpg"
      alt="Elegant cast stone fireplace mantel in a luxury DFW home"
      fetchpriority="high"
    />
    <div class="page-hero__overlay" aria-hidden="true"></div>
    <div class="page-hero__content">
      <div class="container">
        <p class="hero__eyebrow">Free Consultation</p>
        <h1 class="page-hero__heading">
          Let's Design Your<br /><em>Perfect Fireplace</em>
        </h1>
        <p class="page-hero__sub">No pressure. No obligation. Just a conversation about your vision.</p>
        <div class="hero-cta-wrap">
          <a href="/consultation" class="hero-cta-btn">
            Start Your Free Consultation
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
            </svg>
          </a>
          <span class="hero-cta-note">2-minute form · No commitment required</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ PROCESS + CONTACT INFO ═══ -->
  <section class="contact-section" aria-labelledby="contact-heading">
    <div class="container">

      <div class="contact-intro">
        <p class="section-label">What Happens Next</p>
        <h2 id="contact-heading" class="contact-info__heading">
          A seamless process from first call to finished piece
        </h2>
        <p class="contact-info__body">
          Whether you have a clear vision or are just starting to explore ideas, our team is here to help. Fill in the form and we'll reach out within one business day to schedule your free in-home consultation.
        </p>
      </div>

      <!-- Steps 2×2 grid -->
      <ol class="contact-steps-grid" aria-label="Our consultation process">
        <li class="contact-step">
          <div class="contact-step__num" aria-hidden="true">01</div>
          <div>
            <h3 class="contact-step__title">Submit Your Request</h3>
            <p class="contact-step__desc">Share a few details about your project — takes about 2 minutes.</p>
          </div>
        </li>
        <li class="contact-step">
          <div class="contact-step__num" aria-hidden="true">02</div>
          <div>
            <h3 class="contact-step__title">We Call You Back</h3>
            <p class="contact-step__desc">A Cast Design specialist will follow up within one business day to discuss your project.</p>
          </div>
        </li>
        <li class="contact-step">
          <div class="contact-step__num" aria-hidden="true">03</div>
          <div>
            <h3 class="contact-step__title">In-Home Consultation</h3>
            <p class="contact-step__desc">We visit your home, take measurements, and present a custom design concept — free of charge.</p>
          </div>
        </li>
        <li class="contact-step">
          <div class="contact-step__num" aria-hidden="true">04</div>
          <div>
            <h3 class="contact-step__title">Your Quote, Guaranteed</h3>
            <p class="contact-step__desc">Receive a detailed, fixed-price quote with no hidden fees. Approve it and we get to work.</p>
          </div>
        </li>
      </ol>

      <!-- Contact details horizontal -->
      <div class="contact-details-grid">
        <div class="contact-detail">
          <div class="contact-detail__icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
            </svg>
          </div>
          <div>
            <div class="contact-detail__label">Call or Text</div>
            <a href="tel:+12146214820" class="contact-detail__value">(214) 621-4820</a>
          </div>
        </div>
        <div class="contact-detail">
          <div class="contact-detail__icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
            </svg>
          </div>
          <div>
            <div class="contact-detail__label">Email Us</div>
            <a href="mailto:hello@dallasfireplaces.com" class="contact-detail__value">hello@dallasfireplaces.com</a>
          </div>
        </div>
        <div class="contact-detail">
          <div class="contact-detail__icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
            </svg>
          </div>
          <div>
            <div class="contact-detail__label">Showroom</div>
            <div class="contact-detail__value">309 N Belt Line Rd #117<br />Irving, TX 75061</div>
          </div>
        </div>
        <div class="contact-detail">
          <div class="contact-detail__icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <div>
            <div class="contact-detail__label">Hours</div>
            <div class="contact-detail__value">Mon – Fri: 8 am – 5 pm<br />Sat: By appointment</div>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- ═══ CTA SECTION ═══ -->
  <section class="contact-cta-section" aria-label="Get started">
    <div class="container">
      <p class="contact-cta-section__label">Get Started Today</p>
      <h2 class="contact-cta-section__heading">
        Ready to bring your vision to life?
      </h2>
      <p class="contact-cta-section__sub">
        Our cast stone specialists are ready to help you design the perfect fireplace. It takes about 2 minutes.
      </p>
      <div class="contact-cta-section__actions">
        <a href="/consultation" class="contact-cta-section__btn">
          Start Your Free Consultation
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
          </svg>
        </a>
        <a href="tel:+12146214820" class="contact-cta-section__call">
          Or call (214) 621-4820
        </a>
      </div>
    </div>
  </section>

  <!-- ═══ TRUST STRIP ═══ -->
  <section class="contact-trust" aria-label="Why choose Cast Design">
    <div class="container">
      <div class="contact-trust__grid">
        <div class="contact-trust__item">
          <div class="contact-trust__icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.6">
              <path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z" />
            </svg>
          </div>
          <div class="contact-trust__num">4.9★</div>
          <div class="contact-trust__desc">Average Google Rating across 200+ reviews</div>
        </div>
        <div class="contact-trust__item">
          <div class="contact-trust__icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.6">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <div class="contact-trust__num">20+</div>
          <div class="contact-trust__desc">Years crafting cast stone for DFW homes</div>
        </div>
        <div class="contact-trust__item">
          <div class="contact-trust__icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.6">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" />
            </svg>
          </div>
          <div class="contact-trust__num">500+</div>
          <div class="contact-trust__desc">Custom projects completed in DFW</div>
        </div>
        <div class="contact-trust__item">
          <div class="contact-trust__icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.6">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
            </svg>
          </div>
          <div class="contact-trust__num">100%</div>
          <div class="contact-trust__desc">Satisfaction guaranteed — we don't leave until it's right</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ FOOTER ═══ -->
  <Footer />

</BaseLayout>
